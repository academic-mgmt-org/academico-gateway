# ═══════════════════════════════════════════════════════════════════════════
# REDIS CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════
REDIS_PROTOCOL=
REDIS_HOST=
REDIS_PORT=
REDIS_PASSWORD=

# ═══════════════════════════════════════════════════════════════════════════
# MICROSERVICES CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════
LOGIN_BASE_URL=
LOGIN_API_KEY=

USUARIOS_BASE_URL=
USUARIOS_API_KEY=

CALIFICACIONES_BASE_URL=
CALIFICACIONES_API_KEY=

CATALOGO_BASE_URL=
CATALOGO_API_KEY=

MATRICULAS_BASE_URL=
MATRICULAS_API_KEY=

SOLICITUDES_BASE_URL=
SOLICITUDES_API_KEY=

# ═══════════════════════════════════════════════════════════════════════════
# GATEWAY CACHE CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════
GATEWAY_TOKEN_CACHE_TTL=
GATEWAY_WHITELIST_CACHE_TTL=

# ═══════════════════════════════════════════════════════════════════════════
# ENVIRONMENT MODE
# ═══════════════════════════════════════════════════════════════════════════
# prod | dev
ENV=

# ═══════════════════════════════════════════════════════════
# RATE LIMITING CONFIGURATION
# ═══════════════════════════════════════════════════════════

# Rate Limit por IP (CAPA 1: Protección anti-DDoS global)
RATE_LIMIT_IP_ENABLED=  
RATE_LIMIT_IP_MAX=  
RATE_LIMIT_IP_WINDOW=

# Rate Limit por Usuario (CAPA 2: Control individual)
RATE_LIMIT_USER_ENABLED=
RATE_LIMIT_USER_MAX=
RATE_LIMIT_USER_WINDOW=

# Rate Limit de Uploads (CAPA 3: Control de archivos)
RATE_LIMIT_UPLOAD_ENABLED=
RATE_LIMIT_UPLOAD_MAX=
RATE_LIMIT_UPLOAD_WINDOW=
